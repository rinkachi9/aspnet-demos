{
  "Kafka": {
    "Brokers": [
      "localhost:9092"
    ],
    "ConsumerGroupId": "sample-consumer-group",
    "WorkersCount": 1,
    "Username": "dev",
    "Password": "dev",
    "SaslMechanism": "PLAIN",
    "SecurityProtocol": "Plaintext",
    "ClientId": "backoffice-",
